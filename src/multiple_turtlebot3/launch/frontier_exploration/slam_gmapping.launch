<launch>
  <arg name="robot_name" />
  <node pkg="gmapping" type="slam_gmapping" name="$(arg robot_name)_slam_gmapping" output="screen" args="scan:=/$(arg robot_name)/scan">
    <param name="base_frame" value="/$(arg robot_name)_tf/base_footprint"/>
    <param name="odom_frame" value="/$(arg robot_name)_tf/odom"/>
    <param name="map_frame"  value="/$(arg robot_name)_tf/map"/>
    <param name="minimumScore"  value="50"/>
    <rosparam command="load" file="$(find turtlebot3_slam)/config/gmapping_params.yaml" />
  </node>
</launch>
<!-- vi: set et sw=2: -->
