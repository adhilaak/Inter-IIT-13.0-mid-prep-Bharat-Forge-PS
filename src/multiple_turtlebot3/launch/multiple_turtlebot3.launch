<launch>
  <param name="/use_sim_time" value="true" />

  <env name="GAZEBO_MODEL_PATH" value="${GAZEBO_MODEL_PATH}:$(find warehouse_simulation)/models"/>
  <env name="GAZEBO_RESOURCE_PATH" value="${GAZEBO_RESOURCE_PATH}:$(find warehouse_simulation)/models"/>

  <!-- start world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <!-- You can change the world here -->
    <!--<arg name="world_name" value="$(find dynamic_logistics_warehouse)/worlds/warehouse.world"/>-->
    <!--<arg name="world_name" value="$(find multiple_turtlebot3)/worlds/warehouse.world"/>-->
    <arg name="world_name" value="$(find warehouse_simulation)/worlds/warehouse.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>


  <!-- start gui
  <node name="gazebo_gui" pkg="gazebo" type="gui" respawn="false" output="screen"/>-->

  <!-- Run the map server -->
  <node name="map_server" pkg="map_server" type="map_server" args="$(find multiple_turtlebot3)/map/map.yaml" >
    <param name="frame_id" value="map" />
  </node>

  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find multiple_turtlebot3)/rviz/navigation.rviz"
   output="screen" />

  <!-- include our robots -->
  <include file="$(find multiple_turtlebot3)/launch/robots.launch"/>
</launch>
<!-- vi: set et sw=2: -->
